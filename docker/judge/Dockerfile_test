# ═══════════════════════════════════════════════════════════════════════════════
# IOI/ICPC-Grade Judge Sandbox — Production Dockerfile
# Base: Ubuntu 22.04 + Isolate Sandbox + 4 Language Runtimes (Python, C++, Java, C#)
# ═══════════════════════════════════════════════════════════════════════════════

FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 1: System dependencies + PPAs + repos
# ─────────────────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    pkg-config \
    libcap-dev \
    software-properties-common \
    ca-certificates \
    gnupg \
    wget \
    curl \
    apt-transport-https \
    time \
    && rm -rf /var/lib/apt/lists/*

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 2: Add PPAs and external repos (before installing packages)
# ─────────────────────────────────────────────────────────────────────────────

# Python 3.13 — deadsnakes PPA
RUN add-apt-repository ppa:deadsnakes/ppa -y

# .NET SDK 8.0 — Microsoft APT repo (MUST install while wget/curl still exist)
RUN wget https://packages.microsoft.com/config/ubuntu/22.04/packages-microsoft-prod.deb -O /tmp/packages-microsoft-prod.deb \
    && dpkg -i /tmp/packages-microsoft-prod.deb

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.13 \
    python3.13-venv \
    python3.13-dev \
    g++-12 \
    openjdk-17-jdk-headless \
    dotnet-sdk-8.0 \
    && rm -rf /var/lib/apt/lists/*

# Set g++-12 as default g++
RUN update-alternatives --install /usr/bin/g++ g++ /usr/bin/g++-12 100 \
    && update-alternatives --install /usr/bin/gcc gcc /usr/bin/gcc-12 100

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 6: Build Isolate from source (IOI official sandbox)
# ─────────────────────────────────────────────────────────────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends libsystemd-dev && rm -rf /var/lib/apt/lists/*

RUN git clone --depth=1 https://github.com/ioi/isolate.git /tmp/isolate \
    && cd /tmp/isolate \
    && make -j$(nproc) install \
    && rm -rf /tmp/isolate \
    && sed -i 's/^cg_root.*/cg_root = \/sys\/fs\/cgroup/' /usr/local/etc/isolate

# Verify isolate binary exists
RUN test -f /usr/local/bin/isolate && isolate --version

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 7: Security hardening
# ─────────────────────────────────────────────────────────────────────────────

# Remove dangerous network utilities (AFTER all downloads are done)
RUN rm -f /usr/bin/wget /usr/bin/curl /usr/bin/nc /usr/bin/ncat \
    && rm -f /usr/bin/telnet /usr/bin/ftp

# Non-root user for judge execution
RUN useradd -m -s /bin/bash judgeuser

# Sandbox working directory
RUN mkdir -p /sandbox && chmod 755 /sandbox

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 8: Performance optimization
# ─────────────────────────────────────────────────────────────────────────────

# Pre-compile Python .pyc cache (faster first-run)
RUN python3.13 -m compileall /usr/lib/python3.13/ 2>/dev/null || true

# JVM performance tuning
ENV JAVA_OPTS="-server -XX:+TieredCompilation -XX:TieredStopAtLevel=1"

# .NET telemetry off
ENV DOTNET_CLI_TELEMETRY_OPTOUT=1

# Verify all compilers
RUN echo '=== Compiler Verification ===' \
    && python3.13 --version \
    && g++ --version | head -1 \
    && java --version 2>&1 | head -1 \
    && dotnet --version \
    && isolate --version \
    && echo '=== All compilers OK ==='

# ─────────────────────────────────────────────────────────────────────────────
# STAGE 9: Django and Celery Dependencies (for local testing)
# ─────────────────────────────────────────────────────────────────────────────

# Install Python packages for the Django backend
RUN apt-get update && apt-get install -y --no-install-recommends \
    libpq-dev \
    && rm -rf /var/lib/apt/lists/*

# We will install pip packages for Celery to run
RUN python3.13 -m ensurepip --upgrade \
    && python3.13 -m pip install --no-cache-dir setuptools wheel \
    && python3.13 -m pip install --no-cache-dir celery redis psycopg2-binary django django-redis djangorestframework django-cors-headers drf-yasg requests gunicorn django-environ djangorestframework-simplejwt pillow

WORKDIR /app

CMD ["bash", "-c", "mount -o remount,rw /sys/fs/cgroup || true && python3.13 -m celery -A config worker --loglevel=info --pool=solo"]
